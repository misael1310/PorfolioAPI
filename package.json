{
  "name": "portfolio-api",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "prepare-commit-msg": "exec < /dev/tty && npx cz --hook || true"
    }
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "npm run lint --fix"
    ]
  },
  "scripts": {
    "start": "node -r ts-node/register -r tsconfig-paths/register dist/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint",
    "build": "tsc",
    "prepare": "husky",
    "commit": "cz",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/misael1310/PorfolioAPI.git"
  },
  "author": "Misael Perez",
  "license": "ISC",
  "engines": {
    "node": ">=22.22.0 <23"
  },
  "bugs": {
    "url": "https://github.com/misael1310/PorfolioAPI/issues"
  },
  "homepage": "https://github.com/misael1310/PorfolioAPI#readme",
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.2",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "mysql2": "^3.18.2"
  }
}
